APP_NAME=Creative-Ai
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_LOCALE=en
ALLOW_INDEXING=false
TRUSTED_HOSTS=localhost,127.0.0.1
TRUSTED_PROXIES=127.0.0.1

LOG_CHANNEL=stderr
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_URL=pgsql://creative_ai_dev:local-development-only@postgres:5432/creative_ai_dev
DB_SSLMODE=disable

REDIS_CLIENT=phpredis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
REDIS_PREFIX=creative-ai-dev-database-

SESSION_DRIVER=redis
SESSION_COOKIE=creative_ai_dev_session
SESSION_SECURE_COOKIE=false
CACHE_STORE=redis
CACHE_PREFIX=creative-ai-dev-cache-
QUEUE_CONNECTION=redis
FILESYSTEM_DISK=public

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@example.test
MAIL_FROM_NAME="${APP_NAME}"
