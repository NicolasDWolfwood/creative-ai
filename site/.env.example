APP_NAME=Creative-Ai
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=creative_ai
DB_USERNAME=creative_ai
DB_PASSWORD=change-me

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=creative_ai

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AI_PROVIDER=openai
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:latest
OLLAMA_REQUEST_TIMEOUT=150
OLLAMA_CONTEXT_LENGTH=4096
OLLAMA_KEEP_ALIVE=5m
AI_AUTO_ANALYZE_UPLOADS=false
AI_IMAGE_MAX_WIDTH=768
AI_IMAGE_JPEG_QUALITY=72
AI_REQUEST_TIMEOUT=90

ADMIN_EMAIL=admin@example.com
ADMIN_NAME="Creative-Ai Admin"
ADMIN_PASSWORD=

RUN_MIGRATIONS=false
RUN_LEGACY_IMPORT=false
CREATIVE_AI_LEGACY_PATH=/app/legacy

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
