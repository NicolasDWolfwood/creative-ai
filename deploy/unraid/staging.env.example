# Paste this into the .env tab of the creative-ai-staging stack.
# Replace every replace-me value. Never commit the completed file.
COMPOSE_PROJECT_NAME=creative-ai-staging
DEPLOYMENT_ENV=staging
CREATIVE_AI_IMAGE=ghcr.io/nicolasdwolfwood/creative-ai:staging
CREATIVE_AI_NETWORK=creanet
CREATIVE_AI_IPV4_ADDRESS=10.18.0.223
CREATIVE_AI_STORAGE=/mnt/user/appdata/creative-ai-staging/storage

APP_NAME=Creative-Ai Staging
APP_KEY=replace-me-with-a-generated-base64-key
APP_URL=https://test.creative-ai.nl
ALLOW_INDEXING=false
TRUSTED_HOSTS=test.creative-ai.nl,localhost,127.0.0.1
# Use the reverse proxy container IP or its dedicated Docker-network CIDR.
TRUSTED_PROXIES=replace-me-with-proxy-ip-or-cidr

DB_HOST=10.18.0.171
DB_PORT=5432
DB_DATABASE=creative_ai_staging
DB_USERNAME=creative_ai_staging
DB_PASSWORD=replace-me

REDIS_HOST=10.18.0.173
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=2
REDIS_CACHE_DB=3
REDIS_PREFIX=creative-ai-staging-database-
CACHE_PREFIX=creative-ai-staging-cache-
REDIS_QUEUE_RETRY_AFTER=240
SESSION_COOKIE=creative_ai_staging_session

AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://10.18.0.90:11434
OLLAMA_MODEL=qwen3.5:latest
AI_AUTO_ANALYZE_UPLOADS=false

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ZAI_API_KEY=

ADMIN_EMAIL=replace-me@example.com
ADMIN_NAME=Creative-Ai Staging Admin
ADMIN_PASSWORD=
MAIL_MAILER=log
