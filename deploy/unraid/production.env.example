# Paste this into the .env tab of the creative-ai-production stack.
# Replace every replace-me value. Never commit the completed file.
COMPOSE_PROJECT_NAME=creative-ai-production
DEPLOYMENT_ENV=production
# Replace this deliberately invalid placeholder with the exact digest approved
# by the "Approve image for production" GitHub Actions workflow.
CREATIVE_AI_IMAGE=replace-me-with-ghcr-image-at-sha256-digest
CREATIVE_AI_BIND_IP=192.168.1.176
CREATIVE_AI_PORT=8081
CREATIVE_AI_STORAGE=/mnt/user/appdata/creative-ai-production/storage

APP_NAME=Creative-Ai
APP_KEY=replace-me-with-a-generated-base64-key
APP_URL=https://www.creative-ai.nl
ALLOW_INDEXING=true
TRUSTED_HOSTS=www.creative-ai.nl,creative-ai.nl,localhost,127.0.0.1
# Use the reverse proxy container IP or its dedicated Docker-network CIDR.
TRUSTED_PROXIES=replace-me-with-proxy-ip-or-cidr

DB_HOST=192.168.1.176
DB_PORT=5432
DB_DATABASE=creative_ai_production
DB_USERNAME=creative_ai_production
DB_PASSWORD=replace-me

REDIS_HOST=192.168.1.176
REDIS_PORT=6378
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PREFIX=creative-ai-production-database-
CACHE_PREFIX=creative-ai-production-cache-
REDIS_QUEUE_RETRY_AFTER=240
SESSION_COOKIE=creative_ai_production_session

AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://192.168.1.176:11434
OLLAMA_MODEL=qwen3.5:latest
AI_AUTO_ANALYZE_UPLOADS=false

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ZAI_API_KEY=

ADMIN_EMAIL=replace-me@example.com
ADMIN_NAME=Creative-Ai Admin
ADMIN_PASSWORD=
MAIL_MAILER=log
