# Copy this file to .env for the local Docker development stack.
# Generate APP_KEY with the command documented in README.md.
APP_KEY=replace-with-a-generated-base64-key
APP_URL=http://dev.example.test:8080
DEV_HTTP_BIND=127.0.0.1
DEV_HTTP_PORT=8080
TRUSTED_HOSTS=dev.example.test
TRUSTED_PROXIES=127.0.0.1
SESSION_SECURE_COOKIE=false
