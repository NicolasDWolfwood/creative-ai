APP_NAME=Creative-Ai
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.creative-ai.nl
ALLOW_INDEXING=true
TRUSTED_HOSTS=www.creative-ai.nl,localhost,127.0.0.1
TRUSTED_PROXIES=replace-me-with-proxy-ip-or-cidr

CREATIVE_AI_PORT=8080
CREATIVE_AI_STORAGE=/mnt/user/appdata/creative-ai/storage

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=creative_ai
DB_USERNAME=creative_ai
DB_PASSWORD=change-me

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PREFIX=creative-ai-production-database-
CACHE_PREFIX=creative-ai-production-cache-
REDIS_QUEUE_RETRY_AFTER=240

SESSION_COOKIE=creative_ai_production_session
SESSION_SECURE_COOKIE=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_REQUEST_TIMEOUT=120
ZAI_API_KEY=
ZAI_MODEL=glm-4.6v-flash
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_REQUEST_TIMEOUT=120
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://192.168.1.176:11434
OLLAMA_MODEL=qwen3.5:latest
OLLAMA_REQUEST_TIMEOUT=150
OLLAMA_CONTEXT_LENGTH=4096
OLLAMA_KEEP_ALIVE=5m
AI_AUTO_ANALYZE_UPLOADS=false
AI_IMAGE_MAX_WIDTH=768
AI_IMAGE_JPEG_QUALITY=72
AI_REQUEST_TIMEOUT=90

SESSION_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis
FILESYSTEM_DISK=public

ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Creative-Ai Admin
ADMIN_PASSWORD=

RUN_MIGRATIONS=false
RUN_LEGACY_IMPORT=false
